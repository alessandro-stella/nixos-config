{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "cache_duration": "none"
          },
          "template": "\n╭─",
          "foreground": "p:color15",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "leading_diamond": "",
          "template": "{{ .UserName }}",
          "trailing_diamond": "█",
          "foreground": "p:color15",
          "background": "p:color0",
          "type": "session",
          "style": "diamond"
        },
        {
          "options": {
            "style": "full"
          },
          "trailing_diamond": "",
          "template": " 󰉖 {{ path .Path .Location }}",
          "foreground": "p:color15",
          "background": "p:color12",
          "type": "path",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " ({{ url .UpstreamIcon .UpstreamURL }} {{ url .HEAD .UpstreamURL }}){{ if gt .Ahead 0 }}<#FFFFFF> +{{ .Ahead }}</>{{ end }}{{ if gt .Behind 0 }}<#FFFFFF> -{{ .Behind }}</>{{ end }}{{ if .Working.Changed }}<#FFFFFF>  {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }}<#FFFFFF>  {{ .Staging.String }}</>{{ end }}",
          "foreground": "#FFFFFF",
          "background": "#F05032",
          "type": "git",
          "style": "diamond"
        },
        {
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#339933",
          "type": "node",
          "style": "diamond"
        },
        {
          "options": {
            "display_mode": "files",
            "extensions": [
              "package-lock.json"
            ]
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#CB3837",
          "type": "npm",
          "style": "diamond"
        },
        {
          "options": {
            "display_mode": "files",
            "extensions": [
              "pnpm-lock.yaml"
            ]
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "󰋁 {{ .full }}",
          "foreground": "#FFFFFF",
          "background": "#F69220",
          "type": "pnpm",
          "style": "diamond"
        },
        {
          "options": {
            "display_mode": "files"
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#3776AB",
          "type": "python",
          "style": "diamond"
        },
        {
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#5382A1",
          "type": "java",
          "style": "diamond"
        },
        {
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#777BB4",
          "type": "php",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": "╰─ ❯❯",
          "foreground": "p:color15",
          "type": "text",
          "style": "diamond"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "patch_pwsh_bleed": true,
  "final_space": true,
  "palette": {
    "color0": "#3a3a3b",
    "color1": "#8F7F71",
    "color2": "#9C957E",
    "color3": "#75A097",
    "color4": "#9EB39F",
    "color5": "#C4B092",
    "color6": "#D4CFAE",
    "color7": "#E1DFCE",
    "color8": "#9E9C90",
    "color9": "#8F7F71",
    "color10": "#9C957E",
    "color11": "#75A097",
    "color12": "#9EB39F",
    "color13": "#C4B092",
    "color14": "#D4CFAE",
    "color15": "#E1DFCE"
  }
}
