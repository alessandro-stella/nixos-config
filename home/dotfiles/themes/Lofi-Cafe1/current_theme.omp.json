{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "cache_duration": "none"
          },
          "template": "\n╭─",
          "foreground": "p:color15",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "leading_diamond": "",
          "template": "{{ .UserName }}",
          "trailing_diamond": "█",
          "foreground": "p:color15",
          "background": "p:color0",
          "type": "session",
          "style": "diamond"
        },
        {
          "options": {
            "style": "full"
          },
          "trailing_diamond": "",
          "template": " 󰉖 {{ path .Path .Location }}",
          "foreground": "p:color15",
          "background": "p:color12",
          "type": "path",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " ({{ url .UpstreamIcon .UpstreamURL }} {{ url .HEAD .UpstreamURL }}){{ if gt .Ahead 0 }}<#FFFFFF> +{{ .Ahead }}</>{{ end }}{{ if gt .Behind 0 }}<#FFFFFF> -{{ .Behind }}</>{{ end }}{{ if .Working.Changed }}<#FFFFFF>  {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }}<#FFFFFF>  {{ .Staging.String }}</>{{ end }}",
          "foreground": "#FFFFFF",
          "background": "#F05032",
          "type": "git",
          "style": "diamond"
        },
        {
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#339933",
          "type": "node",
          "style": "diamond"
        },
        {
          "options": {
            "display_mode": "files",
            "extensions": [
              "package-lock.json"
            ]
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#CB3837",
          "type": "npm",
          "style": "diamond"
        },
        {
          "options": {
            "display_mode": "files",
            "extensions": [
              "pnpm-lock.yaml"
            ]
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "󰋁 {{ .full }}",
          "foreground": "#FFFFFF",
          "background": "#F69220",
          "type": "pnpm",
          "style": "diamond"
        },
        {
          "options": {
            "display_mode": "files"
          },
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#3776AB",
          "type": "python",
          "style": "diamond"
        },
        {
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#5382A1",
          "type": "java",
          "style": "diamond"
        },
        {
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ .Full }}",
          "foreground": "#FFFFFF",
          "background": "#777BB4",
          "type": "php",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": "╰─ ❯❯",
          "foreground": "p:color15",
          "type": "text",
          "style": "diamond"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "patch_pwsh_bleed": true,
  "final_space": true,
  "palette": {
    "color0": "#3b3b3d",
    "color1": "#626255",
    "color2": "#67618F",
    "color3": "#B06E6B",
    "color4": "#ACAFCC",
    "color5": "#FFBC93",
    "color6": "#D7E6C0",
    "color7": "#E3EAD7",
    "color8": "#9FA496",
    "color9": "#626255",
    "color10": "#67618F",
    "color11": "#B06E6B",
    "color12": "#ACAFCC",
    "color13": "#FFBC93",
    "color14": "#D7E6C0",
    "color15": "#E3EAD7"
  }
}
